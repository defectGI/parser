# Copy this file to .env and fill in your values. .env is gitignored.
#
# Local model (e.g. Ollama) via OpenAI-compatible endpoint:
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=

# Anthropic:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-opus-4-8
# LLM_API_KEY=sk-ant-...

# Hosted OpenAI-compatible API:
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# Vision model for the pdf parser (hybrid/scanned pages). Every VLM_* variable
# falls back to its LLM_* counterpart, so if LLM_MODEL is already multimodal
# nothing extra is needed here.
# VLM_PROVIDER=openai
# VLM_BASE_URL=http://localhost:11434/v1
# VLM_MODEL=qwen2.5-vl
# VLM_API_KEY=

# Independent second vision model for consensus verification of suspicious
# regions. No fallback on purpose — leave unset to skip crop-and-reread
# (unconfirmed content is then labeled "unverified" with an audit crop).
# VLM2_PROVIDER=anthropic
# VLM2_MODEL=claude-haiku-4-5-20251001
# VLM2_API_KEY=

# Storage locations (see storage_paths.py). All default to the dev-time
# storage/ layout below; set these to move raw input, parsed IR output, and
# the image/crop blob store somewhere else (e.g. in production).
# STORAGE_RAW_DIR=storage/raw
# STORAGE_OUTPUT_DIR=storage/output
# STORAGE_IMAGES_DIR=storage/images

# PDF audit-crop store override, independent of STORAGE_IMAGES_DIR above
# (falls back to it when unset).
# PDF_CROP_DIR=
